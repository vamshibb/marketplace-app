{
 "scripts": {
  "dev": "ts-node-dev --respawn src/index.ts",
  "prebuild": "prisma generate",
  "build": "tsc && cpy \"src/generated/**/*\" \"dist/src/generated\" --parents",
  "start": "node dist/src/index.js",
  "prisma:generate": "prisma generate",
  "prisma:migrate": "prisma migrate dev"
},
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.14.2",
    "cpy-cli": "^7.0.0",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
