generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  products  Product[]
  createdAt DateTime  @default(now())
}
 model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  image       String?
  createdAt   DateTime @default(now())

  sellerId String
  seller   User @relation(fields: [sellerId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
}